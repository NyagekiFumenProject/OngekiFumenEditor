# 默认所有文本文件在提交时归一化为 LF,检出时也保持 LF
* text=auto eol=lf

# 显式标记常见源码/配置文件为文本,统一 LF
*.cs       text eol=lf
*.xaml     text eol=lf
*.csproj   text eol=lf
*.sln      text eol=lf
*.props    text eol=lf
*.targets  text eol=lf
*.json     text eol=lf
*.xml      text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore     text eol=lf

# 二进制文件,不做行尾转换
