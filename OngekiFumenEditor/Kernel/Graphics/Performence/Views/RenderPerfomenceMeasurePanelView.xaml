<mah:MetroWindow
    x:Class="OngekiFumenEditor.Kernel.Graphics.Performence.Views.RenderPerfomenceMeasurePanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:markup="clr-namespace:OngekiFumenEditor.UI.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:OngekiFumenEditor.Kernel.Graphics.Performence.ViewModels"
    Title="{markup:Translate [RenderPerfomenceMeasurePanelTitle]}"
    Width="900"
    Height="650"
    MinWidth="600"
    MinHeight="400"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=vm:RenderPerfomenceMeasurePanelViewModel}"
    Background="{StaticResource EnvironmentWindowBackground}"
    SaveWindowPosition="True"
    SizeToContent="WidthAndHeight"
    Style="{StaticResource MainWindowStyle}"
    mc:Ignorable="d">
    <Grid Margin="8">
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{StaticResource EnvironmentToolWindowText}"
            Text="{markup:Translate [RenderPerfomenceMeasurePanelNoContext]}"
            Visibility="{Binding HasNoRenderContexts, Converter={StaticResource BoolToVisibilityConverter}}" />

        <ScrollViewer
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Visibility="{Binding HasRenderContexts, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander
                            Margin="0,0,0,8"
                            Header="{Binding Header}"
                            IsExpanded="True">
                            <StackPanel>
                                <StackPanel
                                    Margin="8,8,8,0"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource EnvironmentToolWindowText}"
                                        Text="{markup:Translate [RenderPerfomenceMeasurePanelMonitor]}" />
                                    <ComboBox
                                        Width="260"
                                        VerticalAlignment="Center"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{Binding PerfomenceMonitorOptions}"
                                        SelectedItem="{Binding SelectedPerfomenceMonitorOption, Mode=TwoWay}" />
                                </StackPanel>
                                <Border
                                    Margin="8"
                                    Padding="8"
                                    Background="{StaticResource EnvironmentWindowBackground}"
                                    BorderBrush="LightGray"
                                    BorderThickness="1">
                                    <TextBlock
                                        FontFamily="Consolas"
                                        Foreground="{StaticResource EnvironmentToolWindowText}"
                                        Text="{Binding StatisticsText}" />
                                </Border>
                            </StackPanel>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</mah:MetroWindow>
